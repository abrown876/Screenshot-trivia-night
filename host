<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Host Panel — Jamaica Trivia Night</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --purple:#5B5BD6;--purple-dark:#3D3D9E;--purple-light:#EEEEFF;
  --coral:#E8547A;--coral-light:#FDE8EE;
  --green:#1A8A4A;--green-light:#E6F7EE;
  --amber:#E8930A;--amber-light:#FEF3DC;
  --bg:#F4F4FC;--card:#fff;--text:#1A1A3E;--muted:#7A7AAA;--border:#E0E0F0;
  --radius:16px;--shadow:0 4px 20px rgba(91,91,214,.10)
}
html,body{min-height:100vh;background:var(--bg);font-family:'DM Sans',sans-serif;color:var(--text)}
.header{background:var(--purple-dark);padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between}
.header-title{font-family:'Nunito',sans-serif;font-weight:900;font-size:1.2rem;color:#fff}
.header-sub{font-size:12px;color:rgba(255,255,255,.6);margin-top:.1rem}
.host-badge{background:var(--coral);color:#fff;font-family:'Nunito',sans-serif;font-weight:800;font-size:12px;padding:4px 14px;border-radius:20px}
.main{max-width:720px;margin:0 auto;padding:1.5rem;display:flex;flex-direction:column;gap:1.1rem}
.card{background:var(--card);border-radius:var(--radius);padding:1.25rem 1.5rem;box-shadow:var(--shadow)}
.slabel{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.7rem;font-family:'Nunito',sans-serif}
.status-bar{display:flex;align-items:center;justify-content:space-between;border-left:5px solid var(--purple)}
.status-val{font-family:'Nunito',sans-serif;font-weight:900;font-size:1.15rem;color:var(--text)}
.tables-pill{background:var(--purple-light);color:var(--purple);font-family:'Nunito',sans-serif;font-weight:800;font-size:1rem;padding:.4rem 1rem;border-radius:20px}
.q-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem}
.q-title{font-family:'Nunito',sans-serif;font-weight:900;font-size:.95rem;color:var(--text)}
.cat-pill{font-size:11px;font-weight:800;padding:3px 10px;border-radius:20px;font-family:'Nunito',sans-serif}
.ct-h{background:#FEF3DC;color:#8A5500}.ct-f{background:#FAECE7;color:#8A2E0F}
.ct-m{background:#EEF0FF;color:#3D3D9E}.ct-g{background:#E6F7EE;color:#1A6A3A}
.ct-s{background:#FDE8EE;color:#8A1840}.ct-x{background:#F0F0F8;color:#4A4A8A}
.q-text{font-family:'Nunito',sans-serif;font-weight:800;font-size:1.1rem;line-height:1.4;color:var(--text);margin-bottom:.85rem}
.opts-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:.85rem}
.opt-prev{background:var(--bg);border:1.5px solid var(--border);border-radius:10px;padding:.6rem .9rem;font-size:13px;display:flex;align-items:center;gap:.5rem;transition:all .2s}
.opt-prev.correct{background:var(--green-light);border-color:#90D4A8;color:var(--green);font-weight:600}
.opt-l{width:24px;height:24px;border-radius:50%;background:var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--muted);flex-shrink:0;font-family:'Nunito',sans-serif}
.correct .opt-l{background:var(--green);color:#fff}
.answer-box{background:var(--green-light);border:1.5px solid #90D4A8;border-radius:10px;padding:.7rem 1rem;font-size:14px;color:var(--green);font-weight:700;display:none;margin-bottom:.85rem}
.answer-box.show{display:block}
.timer-block{background:var(--purple-light);border-radius:12px;padding:.85rem 1rem;text-align:center}
.timer-big{font-family:'Nunito',sans-serif;font-weight:900;font-size:2.8rem;color:var(--purple);line-height:1;transition:color .3s}
.timer-big.urgent{color:var(--coral)}
.timer-track{height:8px;background:rgba(91,91,214,.2);border-radius:4px;margin-top:.5rem;overflow:hidden}
.timer-fill{height:100%;background:var(--purple);border-radius:4px;transition:width .25s linear}
.timer-fill.urgent{background:var(--coral)}
.controls{display:grid;grid-template-columns:1fr 1fr;gap:.65rem}
.btn{width:100%;padding:13px;border-radius:12px;border:none;font-family:'Nunito',sans-serif;font-size:14px;font-weight:900;cursor:pointer;transition:opacity .15s,transform .1s;display:flex;align-items:center;justify-content:center;gap:.4rem}
.btn:active{transform:scale(.98)}
.btn:disabled{opacity:.35;cursor:not-allowed;transform:none}
.btn-p{background:var(--purple);color:#fff;grid-column:1/-1;font-size:16px;padding:15px}
.btn-a{background:var(--amber);color:#fff}
.btn-g{background:var(--green);color:#fff}
.btn-c{background:var(--coral);color:#fff;grid-column:1/-1}
.q-dots{display:flex;flex-wrap:wrap;gap:.5rem}
.qdot{width:38px;height:38px;border-radius:50%;border:2px solid var(--border);background:var(--bg);font-family:'Nunito',sans-serif;font-weight:800;font-size:13px;cursor:pointer;color:var(--muted);transition:all .2s;display:flex;align-items:center;justify-content:center}
.qdot.done{background:var(--green-light);border-color:var(--green);color:var(--green)}
.qdot.active{background:var(--purple);border-color:var(--purple);color:#fff}
.lb-row{display:flex;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border)}
.lb-row:last-child{border-bottom:none}
.lb-left{display:flex;align-items:center;gap:.5rem}
.lb-medal{font-size:1.1rem;min-width:22px}
.lb-info{}
.lb-team{font-weight:500;font-size:14px}
.lb-email{font-size:11px;color:var(--muted)}
.lb-score{font-family:'Nunito',sans-serif;font-weight:800;font-size:1rem;color:var(--purple)}
.lb-empty{text-align:center;font-size:13px;color:var(--muted);padding:1.25rem 0}
.live-row{display:flex;align-items:center;gap:.4rem;font-size:12px;color:var(--coral);font-weight:700}
.ldot{width:6px;height:6px;border-radius:50%;background:var(--coral);animation:ldp 1.5s infinite}
@keyframes ldp{0%,100%{opacity:1}50%{opacity:.3}}
.rxn-item{display:flex;align-items:center;gap:.6rem;padding:.4rem 0;border-bottom:1px solid var(--border);font-size:13px}
.rxn-item:last-child{border-bottom:none}
</style>
</head>
<body>

<div class="header">
  <div>
    <div class="header-title">🎛️ Host Control Panel</div>
    <div class="header-sub">Jamaica Trivia Night — Screenshot Interactive</div>
  </div>
  <div class="host-badge">HOST</div>
</div>

<div class="main">

  <div class="card status-bar">
    <div><div class="slabel" style="margin-bottom:.2rem">Game status</div><div class="status-val" id="status-val">Ready to start</div></div>
    <div class="tables-pill" id="tables-count">0 tables</div>
  </div>

  <div class="card">
    <div class="q-hdr">
      <div class="q-title" id="q-card-title">Select a question and hit Launch</div>
      <span class="cat-pill" id="q-cat-pill"></span>
    </div>
    <div class="q-text" id="q-text-host">The question text will appear here.</div>
    <div class="answer-box" id="answer-box"></div>
    <div class="opts-grid" id="opts-preview"></div>
    <div class="timer-block" id="timer-block" style="display:none">
      <div class="timer-big" id="host-timer">10</div>
      <div class="timer-track"><div class="timer-fill" id="host-timer-fill" style="width:100%"></div></div>
    </div>
  </div>

  <div class="card">
    <div class="slabel" style="margin-bottom:.85rem">Controls</div>
    <div class="controls">
      <button class="btn btn-p" id="btn-launch" onclick="launchQ()">▶ Launch Q<span id="launch-lbl">1</span></button>
      <button class="btn btn-a" id="btn-pause" onclick="pauseGame()" disabled>⏸ Pause</button>
      <button class="btn btn-g" id="btn-reveal" onclick="revealAnswer()" disabled>👁 Reveal &amp; Stop</button>
      <button class="btn btn-c" id="btn-end" onclick="endGame()" disabled>🏁 End Game</button>
    </div>
  </div>

  <div class="card">
    <div class="slabel">Questions</div>
    <div class="q-dots" id="q-dots"></div>
  </div>

  <div class="card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem">
      <div class="slabel" style="margin-bottom:0">💬 Table reactions</div>
      <div class="live-row"><span class="ldot"></span>Live</div>
    </div>
    <div id="rxn-list"><div class="lb-empty">No reactions yet</div></div>
  </div>

  <div class="card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.85rem">
      <div class="slabel" style="margin-bottom:0">🏆 Leaderboard</div>
      <div class="live-row"><span class="ldot"></span>Live</div>
    </div>
    <div id="lb-list"><div class="lb-empty">No scores yet</div></div>
  </div>

  <!-- Reset -->
  <div class="card" style="border-left:4px solid var(--coral)">
    <div class="section-label" style="margin-bottom:.6rem">⚠️ Reset</div>
    <p style="font-size:13px;color:var(--muted);margin-bottom:.85rem;line-height:1.5">Clears all scores, bonus data and reactions from Firebase. Use this before starting a fresh event.</p>
    <button class="btn btn-coral" onclick="resetLeaderboard()">🗑️ Reset Leaderboard & Scores</button>
  </div>

</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
import { getDatabase, ref, set, onValue, query, orderByChild, limitToLast, remove } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";

const FB={apiKey:"AIzaSyBoxCE9DY4VCHiq8beeaGmX5237KiPuFWA",authDomain:"screenshot-trivia-night.firebaseapp.com",databaseURL:"https://screenshot-trivia-night-default-rtdb.firebaseio.com",projectId:"screenshot-trivia-night",storageBucket:"screenshot-trivia-night.firebasestorage.app",messagingSenderId:"482758352954",appId:"1:482758352954:web:832d1cba008bc0b789d503"};
const app=initializeApp(FB);const db=getDatabase(app);

const QUESTIONS=[
  {cat:'history',q:'In what year did Jamaica gain independence from Britain?',opts:['1958','1960','1962','1966'],ans:2},
  {cat:'music',q:'Which Jamaican artist is known as the "King of Reggae"?',opts:['Peter Tosh','Jimmy Cliff','Toots Hibbert','Bob Marley'],ans:3},
  {cat:'geo',q:'What is the capital city of Jamaica?',opts:['Montego Bay','Port Antonio','Ocho Rios','Kingston'],ans:3},
  {cat:'food',q:'What is the national dish of Jamaica?',opts:['Curry goat and rice','Ackee and saltfish','Jerk chicken','Callaloo and dumplings'],ans:1},
  {cat:'sports',q:'Which Jamaican sprinter holds world records in both 100m and 200m?',opts:['Asafa Powell','Yohan Blake','Shelly-Ann Fraser-Pryce','Usain Bolt'],ans:3},
  {cat:'general',q:'What is the official language of Jamaica?',opts:['Patois only','Spanish','French','English'],ans:3},
  {cat:'history',q:'What was Jamaica\'s original indigenous name?',opts:['Xamayca','Caribia','Hispaniola','Taino'],ans:0},
  {cat:'music',q:'Which music genre originated in Jamaica in the late 1960s?',opts:['Calypso','Soca','Reggae','Dancehall'],ans:2},
  {cat:'geo',q:'Which mountain range contains Jamaica\'s highest peak?',opts:['Santa Cruz Mountains','John Crow Mountains','Blue Mountains','Dry Harbour Mountains'],ans:2},
  {cat:'sports',q:'Which sport made Jamaica famous at the 1988 Winter Olympics?',opts:['Bobsled','Luge','Skeleton','Ski jumping'],ans:0},
];
const CAT_CLASS={history:'ct-h',food:'ct-f',music:'ct-m',geo:'ct-g',sports:'ct-s',general:'ct-x'};
const CAT_LABELS={history:'History',food:'Food',music:'Music',geo:'Geography',sports:'Sports',general:'General'};
const LETTERS=['A','B','C','D'];
const MEDALS=['🥇','🥈','🥉'];
const TIMER_SECS=10;

let selQ=0,currentQ=-1,timerInt=null,timeLeft=0,qLive=false,doneQs=new Set();

document.getElementById('q-dots').innerHTML=QUESTIONS.map((_,i)=>`<div class="qdot ${i===0?'active':''}" id="dot-${i}" onclick="selQuestion(${i})">${i+1}</div>`).join('');

window.selQuestion=function(i){
  if(doneQs.has(i)||qLive) return;
  selQ=i;
  document.querySelectorAll('.qdot').forEach((d,idx)=>{if(!doneQs.has(idx))d.classList.remove('active');});
  document.getElementById('dot-'+i).classList.add('active');
  previewQ(i);
  document.getElementById('launch-lbl').textContent=i+1;
};

function previewQ(i){
  const q=QUESTIONS[i];
  document.getElementById('q-card-title').textContent='Question '+(i+1)+' of '+QUESTIONS.length;
  const c=document.getElementById('q-cat-pill');
  c.textContent=CAT_LABELS[q.cat]||q.cat;c.className='cat-pill '+CAT_CLASS[q.cat];
  document.getElementById('q-text-host').textContent=q.q;
  document.getElementById('answer-box').classList.remove('show');
  document.getElementById('opts-preview').innerHTML=q.opts.map((o,idx)=>`
    <div class="opt-prev ${idx===q.ans?'correct':''}">
      <span class="opt-l">${LETTERS[idx]}</span>${o}
    </div>`).join('');
}
previewQ(0);

window.launchQ=async function(){
  if(qLive) return;
  const idx=selQ;qLive=true;
  document.getElementById('btn-launch').disabled=true;
  document.getElementById('btn-pause').disabled=false;
  document.getElementById('btn-reveal').disabled=false;
  document.getElementById('btn-end').disabled=false;
  document.getElementById('answer-box').classList.remove('show');
  document.getElementById('timer-block').style.display='block';
  document.getElementById('status-val').textContent='Q'+(idx+1)+' is live — '+TIMER_SECS+'s on the clock';
  await set(ref(db,'host/command'),{action:'question',index:idx,timestamp:Date.now()});
  startTimer(idx);
};

function startTimer(idx){
  if(timerInt){clearInterval(timerInt);timerInt=null;}
  timeLeft=TIMER_SECS;updateTimer(timeLeft);
  timerInt=setInterval(()=>{
    timeLeft--;updateTimer(timeLeft);
    document.getElementById('status-val').textContent='Q'+(idx+1)+' live — '+timeLeft+'s remaining';
    if(timeLeft<=0){clearInterval(timerInt);timerInt=null;finishQ(idx);}
  },1000);
}

function updateTimer(t){
  const n=document.getElementById('host-timer');
  const f=document.getElementById('host-timer-fill');
  n.textContent=t;
  f.style.width=((t/TIMER_SECS)*100)+'%';
  n.className='timer-big'+(t<=3?' urgent':'');
  f.className='timer-fill'+(t<=3?' urgent':'');
}

function finishQ(idx){
  qLive=false;doneQs.add(idx);
  document.getElementById('dot-'+idx).classList.remove('active');
  document.getElementById('dot-'+idx).classList.add('done');
  document.getElementById('btn-pause').disabled=true;
  document.getElementById('btn-reveal').disabled=true;
  document.getElementById('status-val').textContent='Q'+(idx+1)+' done — paused';
  const next=idx+1;
  if(next<QUESTIONS.length){
    selQ=next;
    document.getElementById('dot-'+next).classList.add('active');
    document.getElementById('launch-lbl').textContent=next+1;
    previewQ(next);document.getElementById('btn-launch').disabled=false;
  } else {
    document.getElementById('btn-launch').disabled=true;
    document.getElementById('status-val').textContent='All done — end the game when you\'re ready';
  }
}

window.revealAnswer=async function(){
  if(timerInt){clearInterval(timerInt);timerInt=null;}
  const idx=selQ;const q=QUESTIONS[idx];
  const box=document.getElementById('answer-box');
  box.textContent='✓ Answer: '+LETTERS[q.ans]+' — '+q.opts[q.ans];
  box.classList.add('show');
  updateTimer(0);
  document.getElementById('status-val').textContent='Answer revealed for Q'+(idx+1);
  document.getElementById('btn-reveal').disabled=true;
  document.getElementById('btn-pause').disabled=true;
  await set(ref(db,'host/command'),{action:'reveal',index:idx,timestamp:Date.now()});
  finishQ(idx);
};

window.pauseGame=async function(){
  if(timerInt){clearInterval(timerInt);timerInt=null;}
  qLive=false;
  document.getElementById('btn-pause').disabled=true;
  document.getElementById('btn-launch').disabled=false;
  document.getElementById('status-val').textContent='Paused — tables are waiting for you';
  await set(ref(db,'host/command'),{action:'pause',timestamp:Date.now()});
};

window.endGame=async function(){
  if(!confirm('Ready to end the game? All tables will see their final results.')) return;
  if(timerInt){clearInterval(timerInt);timerInt=null;}
  ['btn-end','btn-launch','btn-pause','btn-reveal'].forEach(id=>document.getElementById(id).disabled=true);
  document.getElementById('status-val').textContent='Game over — results showing on all tablets';
  await set(ref(db,'host/command'),{action:'end',timestamp:Date.now()});
};

window.resetLeaderboard=async function(){
  if(!confirm('This will permanently delete all scores, bonus data and reactions. Are you sure?')) return;
  try{
    await remove(ref(db,'scores'));
    await remove(ref(db,'race'));
    await remove(ref(db,'reactions'));
    await remove(ref(db,'host/command'));
    document.getElementById('lb-list').innerHTML='<div class="lb-empty">Leaderboard cleared — ready for a new game!</div>';
    document.getElementById('status-val').textContent='Reset complete — ready to start';
    alert('Done! Leaderboard cleared and ready for a fresh game.');
  }catch(e){
    alert('Something went wrong. Try deleting the scores node manually in Firebase.');
  }
};

onValue(query(ref(db,'reactions'),orderByChild('timestamp'),limitToLast(6)),snapshot=>{
  const data=snapshot.val();
  const el=document.getElementById('rxn-list');
  if(!data){el.innerHTML='<div class="lb-empty">No reactions yet</div>';return;}
  const items=Object.values(data).sort((a,b)=>b.timestamp-a.timestamp);
  el.innerHTML=items.map(r=>`
    <div class="rxn-item">
      <span style="font-size:1.2rem">${r.emoji}</span>
      <span style="font-weight:500">${r.team}</span>
      <span style="color:var(--muted);font-size:11px;margin-left:auto">Q${r.q+1}</span>
    </div>`).join('');
});

onValue(ref(db,'scores'),snapshot=>{
  const data=snapshot.val();
  if(!data){
    document.getElementById('lb-list').innerHTML='<div class="lb-empty">No scores yet</div>';
    document.getElementById('tables-count').textContent='0 tables';return;
  }
  const best={};
  Object.values(data).forEach(e=>{if(!best[e.team]||e.score>best[e.team].score)best[e.team]=e;});
  const sorted=Object.values(best).sort((a,b)=>b.score-a.score);
  document.getElementById('tables-count').textContent=sorted.length+' table'+(sorted.length!==1?'s':'');
  document.getElementById('lb-list').innerHTML=sorted.slice(0,8).map((e,i)=>`
    <div class="lb-row">
      <div class="lb-left">
        <span class="lb-medal">${MEDALS[i]||'#'+(i+1)}</span>
        <div class="lb-info">
          <div class="lb-team">${e.team}</div>
          <div class="lb-email">${Array.isArray(e.emails)?e.emails.join(', '):(e.email||'')}</div>
        </div>
      </div>
      <span class="lb-score">${e.score} / ${e.total}</span>
    </div>`).join('');
});
</script>
</body>
</html>
